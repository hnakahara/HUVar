# ============================================================================
# acmg-classifier .gitignore
# ============================================================================

# ----- Local databases / annotation resources (DO NOT COMMIT) ---------------
# Reference genomes, VEP cache, gnomAD, ClinVar, AlphaMissense, SpliceAI,
# RepeatMasker, etc. are several hundred GB in total and must be obtained
# from upstream sources via `python scripts/setup_data.py`.
data/
!data/.gitkeep
!data/shared/gene_inheritance.tsv

# Sample input/output VCFs and result files placed at repo root during dev
*.vcf
*.vcf.gz
*.vcf.gz.tbi
*.vcf.bgz
*.vcf.bgz.tbi
*.bed
*.bed.gz
*.fa
*.fa.gz
*.fasta
*.fai
*.bam
*.bai
*.cram
*.crai
*.duckdb
*.sqlite
*.sqlite3
*.db
results/
output/
tmp/
scratch/
paper/
resources/clingen/cspec_json/
resources/clingen/CSpecList.tsv
resources/gff/


# Exception: keep tiny test fixtures shipped with the repo
!tests/fixtures/*.vcf
!tests/fixtures/*.tsv

# ----- Python ----------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

